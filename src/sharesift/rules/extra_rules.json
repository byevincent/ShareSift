      ],
      "description": "OpenVPN config with auth-user-pass directive pointing at a credential file. The directive's argument is a relative or absolute path containing user+pass on two lines. Promotes the path-tier (.ovpn) Yellow to Red because the file points at a real creds artifact. Closes the Snaffler-#119 'VPN creds' content-side gap."
    },
    {
      "rule_name": "ShareSiftKeepCiscoAnyconnectXml",
      "triage": "Yellow",
      "match_action": "Snaffle",
      "match_location": "FileName",
