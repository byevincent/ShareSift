      "description": "Double-dash CLI password flags: --password=value, --passphrase=value, --password value, --passphrase value. Snaffler's KeepPassOrKeyInCode catches single-dash -password but not the GNU-style double-dash form (gpg --batch --passphrase=, openssl, mysqldump --password). Closes Snaffler #158's TP gap."
    },
    {
      "rule_name": "ShareSiftKeepCiscoEnableSecret",
      "triage": "Red",
      "match_action": "Snaffle",
      "match_location": "FileContentAsString",
      "wordlist_type": "Regex",
      "wordlist": [
