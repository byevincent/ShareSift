        "(^|\\n)\\s*enable\\s+password\\s+\\S+",
        "(^|\\n)\\s*username\\s+\\S+\\s+(privilege\\s+\\d+\\s+)?(password|secret)\\s+[0-7]?\\s*\\S+",
        "(^|\\n)\\s*password\\s+7\\s+[0-9A-F]{4,}"
