        ".*\\.(php|inc|conf|cfg|ini|env|yml|yaml|properties|sh)\\.bak$",
        ".*\\.(php|inc|conf|cfg|ini|env|yml|yaml|properties|sh)\\.swp$",
        ".*\\.(php|inc|conf|cfg|ini|env|yml|yaml|properties|sh)\\.orig$"
      ],
      "description": "Editor backup of a credential-shaped config file — vim's .swp, nano/gedit's ~ suffix, .bak / .orig versions left behind. The original file may be redacted; the backup often isn't. Common DVWA-class finding pattern."
    },
    {
      "rule_name": "ShareSiftKeepSshHostPubKeys",
      "triage": "Yellow",
      "match_action": "Snaffle",
      "match_location": "FilePath",
      "wordlist_type": "Regex",
      "wordlist": [
        "/etc/ssh/ssh_host_(rsa|dsa|ecdsa|ed25519)_key\\.pub$"
      ],
      "description": "SSH host public keys. Not credentials in themselves but: (a) identify hosts being scanned; (b) signal the private-key files are present in the same dir (the parent /etc/ssh/ rule + walk picks those up); (c) useful for host fingerprinting in larger engagement workflows."
    },
    {
      "rule_name": "ShareSiftKeepAnsibleVaultHeader",
      "triage": "Yellow",
