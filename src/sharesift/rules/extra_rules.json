      "description": "MySQL/MariaDB ISAM + InnoDB data files for the mysql.user / mysql.db tables. Contains password hashes (legacy mysql_native_password, sha256_password, caching_sha2_password) that crack offline. Linux DB-server credential surface."
    },
    {
      "rule_name": "ShareSiftKeepEditorBackupConfig",
      "triage": "Red",
      "match_action": "Snaffle",
      "match_location": "FilePath",
      "wordlist_type": "Regex",
